---
import { site, kontaktNauheim, withBase } from '../lib/site';

interface Props {
  /** true = dauerhaft solide (z. B. Seiten ohne Foto-Hero). Sonst transparent über Hero. */
  solid?: boolean;
}
const { solid = false } = Astro.props;

// Menüpunkte sind bewusst Platzhalter (Unterseiten kommen später) -> href '#'.
const navLinks = [
  { label: 'Heizung', href: '#' },
  { label: 'Sanitär & Bad', href: '#' },
  { label: 'Lüftung & Klima', href: '#' },
  { label: 'Gewerbekunden', href: '#' },
  { label: 'Karriere', href: '#' },
];
---

<header class:list={['rb-header', solid ? 'rb-header--solid' : 'rb-header--overlay']} data-header>
  <nav class="hb-nav container" aria-label="Hauptnavigation" data-nav>
    <a class="hb-nav__brand rb-header__brand" href={withBase('/')} aria-label={`${site.legalName} – Startseite`}>
      <img class="rb-logo rb-logo--light" src={withBase('/brand/reibstein-logo-hr-light.png')} alt={site.legalName} width="294" height="40" />
      <img class="rb-logo rb-logo--dark" src={withBase('/brand/reibstein-logo.png')} alt={site.legalName} width="294" height="40" />
    </a>

    <ul class="hb-nav__links">
      {navLinks.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>

    <div class="rb-nav-actions">
      <a class="rb-nav-item" href={`tel:${kontaktNauheim.telefonHref}`}>Notdienst</a>
      <span class="rb-nav-sep" aria-hidden="true"></span>
      <a class="rb-nav-item" href="#kontakt">Kontakt</a>
      <button class="rb-nav-toggle" type="button" aria-label="Menü öffnen" aria-expanded="false" data-nav-toggle>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    var nav = document.querySelector('[data-nav]');
    var btn = document.querySelector('[data-nav-toggle]');
    if (nav && btn) {
      btn.addEventListener('click', function () {
        var open = nav.getAttribute('data-open') === 'true';
        nav.setAttribute('data-open', String(!open));
        btn.setAttribute('aria-expanded', String(!open));
        btn.setAttribute('aria-label', open ? 'Menü öffnen' : 'Menü schließen');
      });
    }

    // Transparente Overlay-Leiste beim Scrollen in Markenblau „andocken".
    var header = document.querySelector('[data-header]');
    if (header && header.classList.contains('rb-header--overlay')) {
      var onScroll = function () {
        header.classList.toggle('is-scrolled', window.scrollY > 24);
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  })();
</script>
