---
import { site, kontaktNauheim, withBase } from '../lib/site';

// Menüpunkte sind bewusst Platzhalter (Unterseiten kommen später) -> href '#'.
const navLinks = [
  { label: 'Heizung', href: '#' },
  { label: 'Sanitär & Bad', href: '#' },
  { label: 'Lüftung & Klima', href: '#' },
  { label: 'Gewerbekunden', href: '#' },
  { label: 'Karriere', href: '#' },
  { label: 'Kontakt', href: '#kontakt' },
];
---

<header class="rb-header">
  <nav class="hb-nav container" aria-label="Hauptnavigation" data-nav>
    <a class="hb-nav__brand" href={withBase('/')} aria-label={`${site.legalName} – Startseite`}>
      <img src={withBase('/brand/reibstein-logo.png')} alt={site.legalName} width="176" height="24" />
    </a>

    <ul class="hb-nav__links">
      {navLinks.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>

    <div class="rb-nav-actions">
      <a class="rb-nav-phone" href={`tel:${kontaktNauheim.telefonHref}`}>
        <img src={withBase('/icons/notdienst.svg')} alt="" width="22" height="22" />
        <span>{kontaktNauheim.telefon}<small>Notdienst &amp; Beratung</small></span>
      </a>
      <a class="hb-btn hb-btn--primary" href="#">Jetzt bewerben</a>
      <button class="rb-nav-toggle" type="button" aria-label="Menü öffnen" aria-expanded="false" data-nav-toggle>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    var nav = document.querySelector('[data-nav]');
    var btn = document.querySelector('[data-nav-toggle]');
    if (!nav || !btn) return;
    btn.addEventListener('click', function () {
      var open = nav.getAttribute('data-open') === 'true';
      nav.setAttribute('data-open', String(!open));
      btn.setAttribute('aria-expanded', String(!open));
      btn.setAttribute('aria-label', open ? 'Menü öffnen' : 'Menü schließen');
    });
  })();
</script>
