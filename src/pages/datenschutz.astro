---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, withBase } from '../lib/site';
---

<Base title={`Datenschutz | ${site.name}`} description="Datenschutzerklärung der Herbert Reibstein GmbH.">
  <Header />
  <main class="section" id="hauptinhalt">
    <div class="container rb-narrow">
      <span class="hb-badge">Rechtliches</span>
      <h1>Datenschutzerklärung</h1>
      <p class="rb-lead">
        <span class="rb-placeholder">Dummytext</span> — Platzhalterinhalte. Vor Veröffentlichung
        durch eine rechtssichere, auf den tatsächlichen Datenverarbeitungsumfang zugeschnittene
        Erklärung ersetzen (DSGVO / BDSG).
      </p>

      <h2>1. Verantwortlicher</h2>
      <p>
        Verantwortlich für die Datenverarbeitung auf dieser Website ist die {site.legalName},
        Musterstraße 1, 64569 Nauheim. <span class="rb-placeholder">Platzhalter</span>
      </p>

      <h2>2. Erhebung und Speicherung personenbezogener Daten</h2>
      <p>
        Beim Aufrufen dieser Website werden durch den Browser automatisch Informationen an den
        Server übermittelt (z. B. IP-Adresse, Datum und Uhrzeit, Browsertyp). Diese Daten dienen
        der technischen Auslieferung und Sicherheit. <span class="rb-placeholder">Beispieltext</span>
      </p>

      <h2>3. Kontaktaufnahme</h2>
      <p>
        Bei Kontaktaufnahme (z. B. per Telefon oder E-Mail) werden Ihre Angaben zur Bearbeitung der
        Anfrage gespeichert. <span class="rb-placeholder">Beispieltext</span>
      </p>

      <h2>4. Ihre Rechte</h2>
      <p>
        Sie haben das Recht auf Auskunft, Berichtigung, Löschung, Einschränkung der Verarbeitung,
        Datenübertragbarkeit und Widerspruch. <span class="rb-placeholder">Beispieltext</span>
      </p>

      <h2>5. Hosting</h2>
      <p>
        Diese Website wird als statische Seite ausgeliefert. Angaben zum Hoster
        <span class="rb-placeholder">Platzhalter</span>.
      </p>

      <p class="rb-mt-6"><a href={withBase('/')}>← Zurück zur Startseite</a></p>
    </div>
  </main>
  <Footer />
</Base>
